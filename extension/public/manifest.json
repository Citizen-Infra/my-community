{
  "manifest_version": 3,
  "key": "",
  "name": "My Community",
  "version": "0.3.16",
  "description": "Your new tab: a community dashboard and a tab manager — digests, network, participation, and your saved tabs.",
  "permissions": ["tabs", "storage", "alarms", "downloads", "bookmarks", "identity", "scripting", "activeTab"],
  "host_permissions": [
    "https://eeidclmhfkndimghdyuq.supabase.co/*",
    "https://scenius-digest.vercel.app/*",
    "https://community-admin-server-production.up.railway.app/*",
    "https://api.lu.ma/*",
    "https://*.bsky.network/*",
    "https://bsky.social/*",
    "https://public.api.bsky.app/*",
    "https://plc.directory/*",
    "https://navidrome-jam-production.up.railway.app/*",
    "https://avails.zhgnv.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab.html"
  },
  "commands": {
    "save-to-recent": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Save tab to most recent collection"
    },
    "suggest-to-wiki": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Suggest current page to the community wiki"
    }
  },
  "action": {
    "default_title": "Save & close tab"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
